# Use this in your configuration.yaml under the 'template:' integration, 
# or paste it into your templates.yaml file if you have split your configuration.

- sensor:
    - name: "Zero Hero Session Export"
      unique_id: zero_hero_session_export
      unit_of_measurement: "kWh"
      device_class: energy
      state_class: measurement
      icon: mdi:solar-power
      state: >
        {% set start_exp = states('input_number.zero_hero_export_start') | float(0) %}
        {% set current_exp = states('sensor.goodwe_total_energy_export') | float(0) %} # EDIT: Replace with your GoodWe Total Export sensor
        
        {% if states('input_boolean.zero_hero_enabled') == 'on' and start_exp > 0 %}
          {{ [(current_exp - start_exp), 0] | max | round(2) }}
        {% else %}
          0.0
        {% endif %}

    - name: "Zero Hero Session Profit"
      unique_id: zero_hero_session_profit
      unit_of_measurement: "AUD"
      device_class: monetary
      state_class: measurement
      icon: mdi:currency-usd
      state: >
        {% set kwh_sold = states('sensor.zero_hero_session_export') | float(0) %}
        {% set super_kwh = [kwh_sold, 10] | min %}
        {% set base_kwh = [kwh_sold - 10, 0] | max %}
        {% set profit = ((super_kwh * 0.15) + (base_kwh * 0.06)) | round(2) %}
        
        {% if states('input_boolean.zero_hero_enabled') == 'on' and states('input_number.zero_hero_export_start') | float(0) > 0 %}
          {# Base daily credit is $1.00 #}
          {{ (profit + 1.00) | round(2) }}
        {% else %}
          0.00
        {% endif %}
